# Point the portal at a storage account for the agent working copy.
# Pick ONE backend. If none is set, the portal falls back to Azurite
# (UseDevelopmentStorage=true) for local development.

# --- Option 1: local Azurite (default, no config needed) ---
# (leave everything unset and just run `azurite`)

# --- Option 2: the deployed Function App's storage account (identity-based) ---
# Requires `az login` and the "Storage Blob Data Contributor" role on the account.
# PORTAL_STORAGE_ACCOUNT_URL=https://stnldwouneaobbm.blob.core.windows.net

# --- Option 3: a storage connection string ---
# PORTAL_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Optional layout overrides (defaults shown)
# PORTAL_CONTAINER=agent-projects
# PORTAL_PROJECT=default
# PORTAL_ENVIRONMENT=dev
