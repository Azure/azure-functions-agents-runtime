# Serverless Agent Portal — backend configuration (all optional).

# Subscription scanned by default (overrides the built-in default). The signed-in
# user (browser MSAL sign-in) needs Reader on it.
# PORTAL_SUBSCRIPTION_ID=1a839f1f-10b2-4613-95ad-0800a22abbf2

# MSAL sign-in for the SPA (served at /api/auth/config). Defaults to the same
# first-party app as Polaris. The app registration must list the portal origin
# (e.g. http://localhost:5173) as a SPA redirect URI.
# MSAL_CLIENT_ID=409cf302-c83f-43c3-94eb-ca581ab18c6d
# MSAL_AUTHORITY=https://login.microsoftonline.com/organizations

# Port the Express server listens on (default 8080).
# PORT=8080
